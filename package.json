{
  "name": "node-cv-generator-public",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Generate sample CV and resume PDF, DOCX, and HTML outputs from one structured JSON data source.",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "cv:ats": "tsx scripts/export-cv-ats.ts",
    "cv:polished": "tsx scripts/export-cv-polished.ts",
    "cv:references": "tsx scripts/export-references.ts",
    "cv:pdf": "tsx scripts/export-cv-pdf.ts",
    "cv:docx": "tsx scripts/export-cv-docx.ts",
    "cv:all": "tsx scripts/export-cv-all.ts",
    "cv:ats:local": "CV_INCLUDE_LOCAL_CONTACT=true tsx scripts/export-cv-ats.ts",
    "cv:polished:local": "CV_INCLUDE_LOCAL_CONTACT=true tsx scripts/export-cv-polished.ts",
    "cv:references:local": "CV_INCLUDE_LOCAL_CONTACT=true tsx scripts/export-references.ts",
    "cv:pdf:local": "CV_INCLUDE_LOCAL_CONTACT=true tsx scripts/export-cv-pdf.ts",
    "cv:docx:local": "CV_INCLUDE_LOCAL_CONTACT=true tsx scripts/export-cv-docx.ts",
    "cv:all:local": "CV_INCLUDE_LOCAL_CONTACT=true tsx scripts/export-cv-all.ts",
    "docx:prototype": "tsx scripts/export-docx-prototypes.ts",
    "cv:lint": "tsx scripts/lint-cv.ts",
    "cv:validate": "tsx scripts/lint-cv.ts",
    "cv:ci": "pnpm cv:all && pnpm cv:validate",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "tsx tests/e2e/export-cv.test.ts",
    "check": "pnpm typecheck && pnpm test && pnpm test:e2e && pnpm cv:validate"
  },
  "keywords": [
    "cv",
    "resume",
    "pdf",
    "docx"
  ],
  "license": "UNLICENSED",
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^3.2.0",
    "jsdom": "^26.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "docx": "^9.5.0",
    "playwright": "^1.52.0",
    "zod": "^4.4.3"
  }
}
